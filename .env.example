# ─────────────────────────────────────────────────────────────
# Syllabi.ai — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────────────────────

# ── Anthropic (Claude AI) ─────────────────────────────────────
# Get your key at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ── Supabase ──────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard → Project Settings → API
# Note: The code uses NEXT_PUBLIC_* versions for public keys (safe for client-side)
# and SUPABASE_SERVICE_ROLE_KEY for server-side operations (KEEP SECRET)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Stripe ────────────────────────────────────────────────────
# Get keys from: dashboard.stripe.com/apikeys (make sure you're in LIVE mode)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Stripe Price IDs (EUR — canonical since 2026-04-09)
# Pro: €28/mo  ·  5-Pack: €33 one-time  ·  Pro Max: €69/mo
NEXT_PUBLIC_STRIPE_PRO_PRICE_ID=price_1TKBpS3kBvceiBKLANxOEgzs
NEXT_PUBLIC_STRIPE_5PACK_PRICE_ID=price_1TKBpT3kBvceiBKLgw6NIFap
NEXT_PUBLIC_STRIPE_PROMAX_PRICE_ID=price_1TKBpU3kBvceiBKLmKdWHeub

# ── Resend (Welcome Emails) ──────────────────────────────────
# Sign up at: https://resend.com → Get API key (free tier: 100 emails/day)
# Add your domain in Resend dashboard for custom sender address
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=Syllabi.ai <welcome@syllabi.ai>

# ── Internal API Security ────────────────────────────────────
# Random secret to protect internal API routes (generate with: openssl rand -hex 32)
INTERNAL_API_SECRET=your-random-secret-here

# ── App URL ───────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Grounded generation (Phase 1 academic) ────────────────────
# Feature flag for the grounded-content pipeline. When true, academic
# courses go through the two-call pipeline (web_search + generate) with
# DOI-verified citations. See docs/cloud-run.md + Notion runbook.
GROUNDED_GENERATION_ENABLED=false

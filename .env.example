# ─────────────────────────────────────────────────────────────
# Syllabi.ai — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────────────────────

# ── Anthropic (Claude AI) ─────────────────────────────────────
# Get your key at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ── Supabase ──────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard → Project Settings → API
# Note: The code uses NEXT_PUBLIC_* versions for public keys (safe for client-side)
# and SUPABASE_SERVICE_ROLE_KEY for server-side operations (KEEP SECRET)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Stripe ────────────────────────────────────────────────────
# Get keys from: dashboard.stripe.com/apikeys (make sure you're in LIVE mode)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Stripe Price IDs (launch promo prices — switch back after May 11, 2026)
NEXT_PUBLIC_STRIPE_PRO_PRICE_ID=price_1THU2d3kBvceiBKLeH3Hrq1l
NEXT_PUBLIC_STRIPE_5PACK_PRICE_ID=price_1THU2e3kBvceiBKLZByaCJhs
NEXT_PUBLIC_STRIPE_PROMAX_PRICE_ID=price_1THU2f3kBvceiBKL88FKLczZ

# ── Resend (Welcome Emails) ──────────────────────────────────
# Sign up at: https://resend.com → Get API key (free tier: 100 emails/day)
# Add your domain in Resend dashboard for custom sender address
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=Syllabi.ai <welcome@syllabi.ai>

# ── Internal API Security ────────────────────────────────────
# Random secret to protect internal API routes (generate with: openssl rand -hex 32)
INTERNAL_API_SECRET=your-random-secret-here

# ── App URL ───────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
